Entities/
excel/
docs/
api/
backend/database/
mysql/

# --- Dependencies ---
node_modules/
backend/vendor/

# --- Build Outputs ---
dist/
dist-ssr/
build/

# --- Logs & Cache ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
.phpunit.result.cache

# --- User Uploads ---
