{
  "name": "Payroll",
  "type": "object",
  "properties": {
    "payroll_number": {
      "type": "string",
      "description": "\u0631\u0642\u0645 \u0645\u0633\u064a\u0631 \u0627\u0644\u0631\u0627\u062a\u0628"
    },
    "employee_id": {
      "type": "string",
      "description": "\u0645\u0639\u0631\u0641 \u0627\u0644\u0645\u0648\u0638\u0641"
    },
    "month": {
      "type": "number",
      "description": "\u0627\u0644\u0634\u0647\u0631"
    },
    "year": {
      "type": "number",
      "description": "\u0627\u0644\u0633\u0646\u0629"
    },
    "payroll_date": {
      "type": "string",
      "format": "date",
      "description": "\u062a\u0627\u0631\u064a\u062e \u0627\u0644\u0631\u0627\u062a\u0628"
    },
    "basic_salary": {
      "type": "number",
      "description": "\u0627\u0644\u0631\u0627\u062a\u0628 \u0627\u0644\u0623\u0633\u0627\u0633\u064a"
    },
    "housing_allowance": {
      "type": "number",
      "description": "\u0628\u062f\u0644 \u0627\u0644\u0633\u0643\u0646"
    },
    "transport_allowance": {
      "type": "number",
      "description": "\u0628\u062f\u0644 \u0627\u0644\u0645\u0648\u0627\u0635\u0644\u0627\u062a"
    },
    "other_allowances": {
      "type": "number",
      "description": "\u0628\u062f\u0644\u0627\u062a \u0623\u062e\u0631\u0649"
    },
    "additional_allowances": {
      "type": "number",
      "description": "\u0639\u0644\u0627\u0648\u0627\u062a \u0625\u0636\u0627\u0641\u064a\u0629"
    },
    "bonuses_amount": {
      "type": "number",
      "description": "\u0645\u062c\u0645\u0648\u0639 \u0627\u0644\u0645\u0643\u0627\u0641\u0622\u062a"
    },
    "overtime_amount": {
      "type": "number",
      "description": "\u0645\u0628\u0644\u063a \u0627\u0644\u0633\u0627\u0639\u0627\u062a \u0627\u0644\u0625\u0636\u0627\u0641\u064a\u0629"
    },
    "gross_salary": {
      "type": "number",
      "description": "\u0625\u062c\u0645\u0627\u0644\u064a \u0627\u0644\u0631\u0627\u062a\u0628"
    },
    "insurance_deduction": {
      "type": "number",
      "description": "\u062e\u0635\u0645 \u0627\u0644\u062a\u0623\u0645\u064a\u0646\u0627\u062a"
    },
    "late_deduction": {
      "type": "number",
      "description": "\u062e\u0635\u0645 \u0627\u0644\u062a\u0623\u062e\u064a\u0631"
    },
    "absence_deduction": {
      "type": "number",
      "description": "\u062e\u0635\u0645 \u0627\u0644\u063a\u064a\u0627\u0628"
    },
    "other_deductions": {
      "type": "number",
      "description": "\u062e\u0635\u0648\u0645\u0627\u062a \u0623\u062e\u0631\u0649"
    },
    "total_deductions": {
      "type": "number",
      "description": "\u0625\u062c\u0645\u0627\u0644\u064a \u0627\u0644\u062e\u0635\u0648\u0645\u0627\u062a"
    },
    "net_salary": {
      "type": "number",
      "description": "\u0635\u0627\u0641\u064a \u0627\u0644\u0631\u0627\u062a\u0628"
    },
    "currency": {
      "type": "string",
      "enum": [
        "SAR",
        "EGP",
        "USD"
      ],
      "default": "SAR"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "pending_review",
        "approved",
        "paid"
      ],
      "default": "draft"
    },
    "issue_date": {
      "type": "string",
      "format": "date",
      "description": "\u062a\u0627\u0631\u064a\u062e \u0627\u0644\u0625\u0635\u062f\u0627\u0631"
    },
    "working_days": {
      "type": "number",
      "description": "\u0623\u064a\u0627\u0645 \u0627\u0644\u0639\u0645\u0644 \u0627\u0644\u0641\u0639\u0644\u064a\u0629"
    },
    "absent_days": {
      "type": "number",
      "description": "\u0623\u064a\u0627\u0645 \u0627\u0644\u063a\u064a\u0627\u0628"
    },
    "late_minutes": {
      "type": "number",
      "description": "\u062f\u0642\u0627\u0626\u0642 \u0627\u0644\u062a\u0623\u062e\u064a\u0631"
    },
    "overtime_hours": {
      "type": "number",
      "description": "\u0633\u0627\u0639\u0627\u062a \u0627\u0644\u0639\u0645\u0644 \u0627\u0644\u0625\u0636\u0627\u0641\u064a"
    },
    "allowances_breakdown": {
      "type": "array",
      "description": "\u062a\u0641\u0635\u064a\u0644 \u0627\u0644\u0639\u0644\u0627\u0648\u0627\u062a",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          }
        }
      }
    },
    "deductions_breakdown": {
      "type": "array",
      "description": "\u062a\u0641\u0635\u064a\u0644 \u0627\u0644\u062e\u0635\u0648\u0645\u0627\u062a",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          }
        }
      }
    },
    "bonuses_breakdown": {
      "type": "array",
      "description": "\u062a\u0641\u0635\u064a\u0644 \u0627\u0644\u0645\u0643\u0627\u0641\u0622\u062a",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          }
        }
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "employee_id",
    "month",
    "year"
  ]
}