{
  "name": "Resignation",
  "type": "object",
  "properties": {
    "request_number": {
      "type": "string",
      "description": "\u0631\u0642\u0645 \u0627\u0644\u0637\u0644\u0628 \u0627\u0644\u062a\u0644\u0642\u0627\u0626\u064a"
    },
    "employee_id": {
      "type": "string",
      "description": "\u0645\u0639\u0631\u0641 \u0627\u0644\u0645\u0648\u0638\u0641"
    },
    "resignation_date": {
      "type": "string",
      "format": "date",
      "description": "\u062a\u0627\u0631\u064a\u062e \u062a\u0642\u062f\u064a\u0645 \u0627\u0644\u0627\u0633\u062a\u0642\u0627\u0644\u0629"
    },
    "end_of_service_date": {
      "type": "string",
      "format": "date",
      "description": "\u062a\u0627\u0631\u064a\u062e \u0646\u0647\u0627\u064a\u0629 \u0627\u0644\u062e\u062f\u0645\u0629"
    },
    "reason": {
      "type": "string",
      "description": "\u0633\u0628\u0628 \u0627\u0644\u0627\u0633\u062a\u0642\u0627\u0644\u0629"
    },
    "notice_period_days": {
      "type": "number",
      "default": 30,
      "description": "\u0641\u062a\u0631\u0629 \u0627\u0644\u0625\u0634\u0639\u0627\u0631 \u0628\u0627\u0644\u0623\u064a\u0627\u0645"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "rejected",
        "cancelled"
      ],
      "default": "pending",
      "description": "\u062d\u0627\u0644\u0629 \u0627\u0644\u0637\u0644\u0628"
    },
    "current_approval_level": {
      "type": "string",
      "description": "\u0627\u0644\u0645\u0633\u062a\u0648\u0649 \u0627\u0644\u062d\u0627\u0644\u064a \u0644\u0644\u0627\u0639\u062a\u0645\u0627\u062f"
    },
    "approval_history": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "level": {
            "type": "string"
          },
          "approver_id": {
            "type": "string"
          },
          "approver_name": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "date": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      },
      "description": "\u0633\u062c\u0644 \u0627\u0644\u0627\u0639\u062a\u0645\u0627\u062f\u0627\u062a"
    },
    "notes": {
      "type": "string",
      "description": "\u0645\u0644\u0627\u062d\u0638\u0627\u062a \u0625\u0636\u0627\u0641\u064a\u0629"
    },
    "final_settlement_amount": {
      "type": "number",
      "description": "\u0645\u0628\u0644\u063a \u0627\u0644\u062a\u0633\u0648\u064a\u0629 \u0627\u0644\u0646\u0647\u0627\u0626\u064a\u0629"
    },
    "exit_interview_notes": {
      "type": "string",
      "description": "\u0645\u0644\u0627\u062d\u0638\u0627\u062a \u0645\u0642\u0627\u0628\u0644\u0629 \u0627\u0644\u062e\u0631\u0648\u062c"
    },
    "attachments": {
      "type": "array",
      "description": "\u0627\u0644\u0645\u0631\u0641\u0642\u0627\u062a",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "upload_date": {
            "type": "string"
          }
        }
      }
    },
    "clearance_form": {
      "type": "object",
      "description": "\u0646\u0645\u0648\u0630\u062c \u0627\u0633\u062a\u0644\u0627\u0645 \u0627\u0644\u0645\u0633\u062a\u062d\u0642\u0627\u062a",
      "properties": {
        "employee_signature": {
          "type": "string"
        },
        "employee_signature_date": {
          "type": "string"
        },
        "hr_signature": {
          "type": "string"
        },
        "hr_signature_date": {
          "type": "string"
        },
        "items_received": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "item": {
                "type": "string"
              },
              "received": {
                "type": "boolean"
              },
              "notes": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "required": [
    "employee_id",
    "resignation_date",
    "end_of_service_date",
    "reason"
  ]
}