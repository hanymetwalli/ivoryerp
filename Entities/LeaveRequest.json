{
  "name": "LeaveRequest",
  "type": "object",
  "properties": {
    "request_number": {
      "type": "string",
      "description": "\u0631\u0642\u0645 \u0627\u0644\u0637\u0644\u0628 \u0627\u0644\u062a\u0644\u0642\u0627\u0626\u064a"
    },
    "employee_id": {
      "type": "string",
      "description": "\u0645\u0639\u0631\u0641 \u0627\u0644\u0645\u0648\u0638\u0641"
    },
    "leave_type_id": {
      "type": "string",
      "description": "\u0646\u0648\u0639 \u0627\u0644\u0625\u062c\u0627\u0632\u0629"
    },
    "start_date": {
      "type": "string",
      "format": "date",
      "description": "\u062a\u0627\u0631\u064a\u062e \u0627\u0644\u0628\u062f\u0627\u064a\u0629"
    },
    "end_date": {
      "type": "string",
      "format": "date",
      "description": "\u062a\u0627\u0631\u064a\u062e \u0627\u0644\u0646\u0647\u0627\u064a\u0629"
    },
    "days_count": {
      "type": "number",
      "description": "\u0639\u062f\u062f \u0627\u0644\u0623\u064a\u0627\u0645"
    },
    "reason": {
      "type": "string",
      "description": "\u0627\u0644\u0633\u0628\u0628"
    },
    "document_url": {
      "type": "string",
      "description": "\u0645\u0633\u062a\u0646\u062f \u0645\u0631\u0641\u0642"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "rejected"
      ],
      "default": "pending"
    },
    "current_approval_level": {
      "type": "string",
      "description": "\u0627\u0644\u0645\u0633\u062a\u0648\u0649 \u0627\u0644\u062d\u0627\u0644\u064a \u0644\u0644\u0627\u0639\u062a\u0645\u0627\u062f"
    },
    "approval_history": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "level": {
            "type": "string"
          },
          "approver_id": {
            "type": "string"
          },
          "approver_name": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "date": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      },
      "description": "\u0633\u062c\u0644 \u0627\u0644\u0627\u0639\u062a\u0645\u0627\u062f\u0627\u062a"
    },
    "requires_finance_approval": {
      "type": "boolean",
      "default": true,
      "description": "\u064a\u062a\u0637\u0644\u0628 \u0627\u0639\u062a\u0645\u0627\u062f \u0645\u062f\u064a\u0631 \u0627\u0644\u062d\u0633\u0627\u0628\u0627\u062a"
    }
  },
  "required": [
    "employee_id",
    "leave_type_id",
    "start_date",
    "end_date"
  ]
}