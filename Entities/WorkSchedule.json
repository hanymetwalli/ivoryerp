      "description": "\u0645\u0643\u0627\u0646 \u0627\u0644\u0639\u0645\u0644"
    },
    "start_time": {
      "type": "string",
      "description": "\u0648\u0642\u062a \u0628\u062f\u0627\u064a\u0629 \u0627\u0644\u062f\u0648\u0627\u0645"
    },
    "end_time": {
      "type": "string",
      "description": "\u0648\u0642\u062a \u0646\u0647\u0627\u064a\u0629 \u0627\u0644\u062f\u0648\u0627\u0645"
    },
    "working_days": {
