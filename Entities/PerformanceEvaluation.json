            "type": "string"
          },
          "approver_id": {
            "type": "string"
          },
          "approver_name": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "date": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      },
      "description": "\u0633\u062c\u0644 \u0627\u0644\u0627\u0639\u062a\u0645\u0627\u062f\u0627\u062a"
