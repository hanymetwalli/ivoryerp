{
  "name": "PerformanceEvaluation",
  "type": "object",
  "properties": {
    "evaluation_number": {
      "type": "string",
      "description": "\u0631\u0642\u0645 \u0627\u0644\u062a\u0642\u064a\u064a\u0645"
    },
    "employee_id": {
      "type": "string",
      "description": "\u0645\u0639\u0631\u0641 \u0627\u0644\u0645\u0648\u0638\u0641"
    },
    "template_id": {
      "type": "string",
      "description": "\u0642\u0627\u0644\u0628 \u0627\u0644\u062a\u0642\u064a\u064a\u0645 \u0627\u0644\u0645\u0633\u062a\u062e\u062f\u0645"
    },
    "evaluator_id": {
      "type": "string",
      "description": "\u0627\u0644\u0645\u0642\u064a\u0651\u0645 (\u0627\u0644\u0645\u062f\u064a\u0631 \u0627\u0644\u0645\u0628\u0627\u0634\u0631)"
    },
    "period_start": {
      "type": "string",
