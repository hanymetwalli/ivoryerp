    },
    "overall_score": {
      "type": "number",
      "description": "\u0627\u0644\u062f\u0631\u062c\u0629 \u0627\u0644\u0625\u062c\u0645\u0627\u0644\u064a\u0629"
    },
    "strengths": {
      "type": "string",
      "description": "\u0646\u0642\u0627\u0637 \u0627\u0644\u0642\u0648\u0629 \u0627\u0644\u0631\u0626\u064a\u0633\u064a\u0629"
    },
    "improvement_areas": {
      "type": "string",
      "description": "\u0641\u062c\u0648\u0627\u062a \u0627\u0644\u0623\u062f\u0627\u0621 / \u0641\u0631\u0635 \u0627\u0644\u062a\u062d\u0633\u064a\u0646"
    },
    "development_actions": {
      "type": "string",
      "description": "\u0625\u062c\u0631\u0627\u0621\u0627\u062a \u0627\u0644\u062a\u0637\u0648\u064a\u0631 \u0627\u0644\u0645\u0642\u062a\u0631\u062d\u0629"
    },
    "employee_signature_date": {
      "type": "string",
      "format": "date"
    },
    "evaluator_signature_date": {
      "type": "string",
      "format": "date"
    },
    "hr_signature_date": {
      "type": "string",
      "format": "date"
